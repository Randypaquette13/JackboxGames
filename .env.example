# HTTP + WebSocket server (game simulation)
PORT=3001

# Public origin for QR join links (no trailing slash). Vite exposes this to the host page as import.meta.env.VITE_PUBLIC_BASE_URL.
# Local dev: http://127.0.0.1:5173 — tunnel/ngrok: https://your-subdomain.ngrok-free.app
VITE_PUBLIC_BASE_URL=http://127.0.0.1:5173

# Vite dev: proxy /ws to the game server (must match PORT above).
VITE_WS_PROXY_TARGET=http://127.0.0.1:3001
