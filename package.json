{
  "name": "jackboxclone",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:server\" \"npm run dev:vite\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:vite": "vite",
    "gen:kart-geometry": "tsx scripts/generate-kart-geometry.ts",
    "build": "tsc -p tsconfig.server.json && node scripts/copy-kart-geometry.mjs && vite build",
    "start": "node dist-server/server/index.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "qrcode": "^1.5.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/qrcode": "^1.5.5",
    "@types/ws": "^8.5.13",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
